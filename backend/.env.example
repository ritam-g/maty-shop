# ========================================
# BACKEND ENVIRONMENT CONFIGURATION
# ========================================

# DATABASE CONFIGURATION
# MongoDB connection string
MONGO_URL=your_mongodb_url

# SERVER CONFIGURATION
# LOCAL: Set to 5000 for local development
# PRODUCTION: Leave empty or set to 8080 (Render will override)
PORT=5000

# JWT CONFIGURATION
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# FRONTEND CONFIGURATION
# LOCAL: http://localhost:5173 (Vite development server)
# PRODUCTION: https://maty-shop.onrender.com (your Render frontend URL)
FRONTEND_URL=http://localhost:5173

# GOOGLE OAUTH CONFIGURATION
# LOCAL: http://localhost:5000/api/auth/google/callback
# PRODUCTION: https://maty-shop.onrender.com/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://maty-shop.onrender.com/api/auth/google/callback
CLIENT_ID=your_google_client_id_here
CLIENT_SECRET=your_google_client_secret_here

# IMAGEKIT CONFIGURATION
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key_here
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key_here
IMAGEKIT_URL_ENDPOINT=your_imagekit_url_endpoint_here

# ENVIRONMENT
# LOCAL: development
# PRODUCTION: production
NODE_ENV=development

# HOST CONFIGURATION
# LOCAL: localhost:5000
# PRODUCTION: Leave empty (Render handles this)
APP_HOST=localhost:5000
